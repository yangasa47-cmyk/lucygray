  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

  .figma-internal-showcase-grid-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: auto;
    gap: 8px;
    padding: 16px;
    --internal-grid-cell-container-padding: 12px;
    width: 100%;
    height: 100%;
    overflow-y: auto;
    box-sizing: border-box;
    background-color: var(--figma-internal-color-bg);
  }
  .figma-internal-showcase-grid-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    aspect-ratio: 1.3;
    min-height: 0;
    overflow: hidden;
    background-color: var(--figma-internal-color-bg);
    border-radius: 5px;
    padding: var(--internal-grid-cell-container-padding, 12px);
    /* Containment to keep components bounded */
    isolation: isolate;
    width: 100%;
    height: 100%;
  }
  .figma-internal-showcase-grid-cell:hover {
    background-color: var(--figma-internal-color-bg-hover);
  }
  .figma-internal-showcase-grid-cell::after {
    content: '\u{203A}';
    position: absolute;
    bottom: 8px;
    right: var(--internal-grid-cell-container-padding, 12px);
    font-size: 18px;
    font-weight: 100;
    color: var(--figma-internal-color-tertiary);
    opacity: 0;
  }
  .figma-internal-showcase-grid-cell:hover::after {
    opacity: 1;
  }
  .figma-internal-showcase-grid-cell-content {
    flex: 1;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Responsive inner padding that shrinks on smaller grids */
    padding: var(--internal-grid-cell-padding, clamp(8px, 1vw, 16px));
    /* CSS containment to prevent components from escaping */
    contain: layout style paint;
    /* Ensure content has a defined size for scaling */
    width: 100%;
    height: 100%;
    /* Create containing block for position: fixed descendants so overlays stay within the cell */
    transform: translateZ(0);
    background-color: var(--figma-internal-color-bg-secondary);
    border-radius: 5px;
    justify-content: center;
  }
  .figma-internal-showcase-grid-cell:hover .figma-internal-showcase-grid-cell-content {
    border: 1px solid var(--figma-internal-color-border);
  }
  /* Override fixed positioning to be relative to the cell */
  .figma-internal-showcase-grid-cell-content [style*="position: fixed"],
  .figma-internal-showcase-grid-cell-content [class*="fixed"],
  .figma-internal-showcase-grid-cell-content .fixed {
    position: absolute !important;
  }
  /* Constrain full-screen overlays to stay within bounds */
  /* Handles: inset-0, inset-x-0 + inset-y-0, top-0+left-0+right-0+bottom-0, backdrop classes */
  .figma-internal-showcase-grid-cell-content [style*="inset: 0"],
  .figma-internal-showcase-grid-cell-content [style*="inset:0"],
  .figma-internal-showcase-grid-cell-content .inset-0,
  .figma-internal-showcase-grid-cell-content .inset-x-0.inset-y-0,
  .figma-internal-showcase-grid-cell-content .top-0.left-0.right-0.bottom-0,
  .figma-internal-showcase-grid-cell-content [class*="backdrop"] {
    position: absolute !important;
    inset: 0 !important;
    max-width: 100% !important;
    max-height: 100% !important;
  }
  /* Convert viewport units to percentage-based sizing within the cell */
  .figma-internal-showcase-grid-cell-content .w-screen,
  .figma-internal-showcase-grid-cell-content [style*="100vw"] {
    width: 100% !important;
  }
  .figma-internal-showcase-grid-cell-content .h-screen,
  .figma-internal-showcase-grid-cell-content [style*="100vh"] {
    height: 100% !important;
  }
  /* Handle style attribute with individual position properties */
  .figma-internal-showcase-grid-cell-content [style*="top: 0"][style*="left: 0"][style*="right: 0"][style*="bottom: 0"],
  .figma-internal-showcase-grid-cell-content [style*="top:0"][style*="left:0"][style*="right:0"][style*="bottom:0"] {
    position: absolute !important;
    inset: 0 !important;
    max-width: 100% !important;
    max-height: 100% !important;
  }
  /* Make modal backdrops transparent within grid cells */
  .figma-internal-showcase-grid-cell-content > div > .inset-0.bg-black,
  .figma-internal-showcase-grid-cell-content > div > .inset-0.bg-opacity-50,
  .figma-internal-showcase-grid-cell-content > div > [class*="bg-black"][class*="bg-opacity"],
  .figma-internal-showcase-grid-cell-content .fixed.inset-0.bg-black,
  .figma-internal-showcase-grid-cell-content .absolute.inset-0.bg-black {
    background: transparent !important;
    opacity: 1 !important;
  }
  .figma-internal-showcase-grid-cell-label {
    padding-top: 8px;
    font-family: var(--figma-internal-text-body-medium-font-family);
    font-size: var(--figma-internal-text-body-medium-font-size);
    color: var(--figma-internal-color-text);
    line-height: var(--figma-internal-text-body-medium-line-height);
    letter-spacing: var(--figma-internal-text-body-medium-letter-spacing);
    text-align: left;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .figma-internal-showcase-grid-cell-error {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    color: var(--figma-internal-color-text);
    font-size: 12px;
    text-align: center;
